{
  "manifest_version": 3,
  "name": "AI Text Autocomplete",
  "version": "1.0.0",
  "description": "Inline AI-powered text completions on any website — like Copilot, but for everything you type.",
  "permissions": ["storage"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle",
      "all_frames": true
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Autocomplete Settings"
  }
}